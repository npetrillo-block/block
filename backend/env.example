# ============================================================
# Dashboard Backend — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your actual values.
#   cp env.example .env
# ============================================================

# Snowflake Configuration
# TODO: Fill in your Snowflake credentials
SNOWFLAKE_ACCOUNT=your_account_here
SNOWFLAKE_USER=your_user_here
SNOWFLAKE_PASSWORD=your_password_here
SNOWFLAKE_WAREHOUSE=your_warehouse_here
SNOWFLAKE_DATABASE=your_database_here
SNOWFLAKE_SCHEMA=your_schema_here

# TODO: Replace with your actual Snowflake table names
B2B_LEADS_TABLE=your_database.your_schema.b2b_leads
MONKS_CHANNEL_TABLE=your_database.your_schema.channel_performance

# Slack Configuration
# TODO: Create a Slack webhook at https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Email Configuration
# TODO: Fill in your SMTP settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@company.com
SMTP_PASSWORD=your_app_password_here
EMAIL_FROM=dashboards@company.com
EMAIL_RECIPIENTS=nick@company.com,team@company.com

# Dashboard Settings
REFRESH_HOUR=7
REFRESH_MINUTE=0
STALENESS_THRESHOLD_DAYS=14

# Server Settings
API_HOST=0.0.0.0
API_PORT=8000
